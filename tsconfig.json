{
  "compilerOptions": {
    "composite": true,
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./",
    "outDir": "./build",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "#api/*": ["./api/*"],
      "#business/*": ["./business/*"],
      "#cache/*": ["./cache/*"],
      "#channel/*": ["./channel/*"],
      "#configs/*": ["./configs/*"],
      "#controllers/*": ["./controllers/*"],
      "#events/*": ["./events/*"],
      "#gRPC/*": ["./gRPC/*"],
      "#httpRequest/*": ["./httpRequest/*"],
      "#messages/*": ["./messages/*"],
      "#middlewares/*": ["./middlewares/*"],
      "#models/*": ["./models/*"],
      "#services/*": ["./services/*"],
      "#types/*": ["./types/*"],
      "#utils/*": ["./utils/*"],
      "#env": ["./env"],
      "#server": ["./server"]
    }
  }
}